# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_SECRET=your_admin_password_here

# QR signing (use any 32+ char random string)
QR_SECRET=your_qr_signing_secret_here_make_it_long

# Gupshup WhatsApp
GUPSHUP_API_KEY=
GUPSHUP_SOURCE_NUMBER=
GUPSHUP_APP_NAME=

# Event config (editable without redeploy via admin UI, but seed defaults here)
NEXT_PUBLIC_EVENT_NAME="Zero1 Money Circle"
NEXT_PUBLIC_EVENT_DATE="May 24, 2025"
NEXT_PUBLIC_EVENT_TIME="6:00 PM – 9:00 PM"
NEXT_PUBLIC_EVENT_CITY="Mumbai"
NEXT_PUBLIC_EVENT_VENUE="TBD — sent 24 hrs before"

# Base URL (for generating pass links)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
